# ============================================================
# Daily Cash Tracker — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Google Sheets API ---
# Create an API key at: https://console.cloud.google.com/apis/credentials
# Enable the "Google Sheets API" for your project.
# Restrict the key to the Sheets API and your domain.
GOOGLE_SHEETS_API_KEY=

# Spreadsheet IDs are auto-parsed from the sheet URLs — you can override here:
QUEST_SPREADSHEET_ID=1NdvISYmIBlFRpTQGnCpC8918nM7ImW3xAASgj6dBQwg
LABCORP_SPREADSHEET_ID=1TL-yi9u-8ktDC_b8aLZWfBy_UBm6Yuh3HEMrZga9OEo

# --- Bill.com API (OAuth 2.0) ---
# TODO: Connect Bill.com API — see lib/billcom.ts for implementation details
# OAuth docs: https://developer.bill.com/docs/oauth-2-0
BILLCOM_CLIENT_ID=
BILLCOM_CLIENT_SECRET=
BILLCOM_ORG_ID=
BILLCOM_SESSION_ID=

# --- Stripe ---
# TODO: Connect Stripe API or Google Sheet export — see lib/stripe.ts
STRIPE_API_KEY=
